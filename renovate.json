{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:best-practices"],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "minimumReleaseAge": "7 days",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update aws-msk-iam-auth JAR version in Dockerfile. NOTE: bumping this version requires updating IAM_AUTH_JAR_SHA256 manually.",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "ARG IAM_AUTH_VERSION=(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "aws/aws-msk-iam-auth",
      "datasourceTemplate": "github-releases",
      "extractVersionTemplate": "^v(?<version>.+)$"
    },
    {
      "customType": "regex",
      "description": "Update Confluent Schema Registry base image version in Dockerfile. NOTE: bumping CP_VERSION also requires updating CP_DIGEST manually.",
      "fileMatch": ["^Dockerfile$"],
      "matchStrings": [
        "ARG CP_VERSION=(?<currentValue>\\S+)"
      ],
      "depNameTemplate": "confluentinc/cp-schema-registry",
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "automerge": false,
      "description": "Regex-managed versions require manual digest/checksum updates; never automerge"
    }
  ]
}
